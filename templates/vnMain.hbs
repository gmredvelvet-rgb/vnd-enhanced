{{!--
  VND Enhanced – Main UI Template
  Layout:
    [TOP BAR]        location name (left) | combat controls (center) | buttons (right)
    [LEFT PANEL]     player character portraits (auto-scaling, side cast)
    [CENTER]         roleplay stage (rp-stage) / VS combat display
    [RIGHT PANEL]    NPC portraits (auto-scaling, side cast)
    [BOTTOM BAR]     scene quick-switcher + GM toolbar
    [PLAYER PANEL]   GM: per-player visibility controls
--}}
<div id="vne-main" class="vne-main{{#unless visible}} vne-hidden{{/unless}}{{#if combatMode}} vne-combat-mode{{/if}}"
  style="z-index: {{zIndex}}; display:{{#if visible}}grid{{else}}none{{/if}};">

  {{!-- BACKGROUND — img for stills/GIF/WebP, video for MP4/WebM --}}
  <div id="vne-bg-wrap" class="vne-background{{#if hideBack}} vne-hidden{{/if}}">
    <img   id="vne-background-img" class="vne-bg-img"
           src="{{#unless backgroundIsVideo}}{{backgroundImage}}{{/unless}}" alt=""
           style="{{#if backgroundIsVideo}}display:none;{{/if}}"/>
    <video id="vne-background-vid" class="vne-bg-img"
           autoplay loop muted playsinline
           style="{{#unless backgroundIsVideo}}display:none;{{/unless}}">
      {{#if backgroundIsVideo}}<source src="{{backgroundImage}}"/>{{/if}}
    </video>
  </div>
  <div class="vne-background-overlay"></div>

  {{!-- UI LAYER (hides with hideUI) --}}
  <div id="vne-ui-layer" class="vne-ui-layer{{#if hideUI}} vne-ui-collapsed{{/if}}">

    {{!-- ── TOP BAR ── --}}
    <div class="vne-top-bar{{#if combatMode}} vne-combat-mode{{/if}}">

      {{!-- LEFT: module controls + location info --}}
      <div class="vne-top-left-section">
        <div class="vne-top-controls">
          {{#if isGM}}
            <div id="vne-combat-stage-btn" class="vne-ctrl-btn vne-combat-stage-toggle{{#if combatMode}} vne-active vne-combat-active{{/if}}" title="{{localize 'vnd-enhanced.ui.combatStage'}}">
              <i class="fas fa-crosshairs"></i>
            </div>
            <div id="vne-editmode-btn" class="vne-ctrl-btn{{#if editMode}} vne-active vne-editmode-active{{/if}}" title="{{#if editMode}}{{localize 'vnd-enhanced.ui.editModeOn'}}{{else}}{{localize 'vnd-enhanced.ui.editModeOff'}}{{/if}}">
              <i class="fas fa-{{#if editMode}}lock-open{{else}}pencil-alt{{/if}}"></i>
            </div>
            <div id="vne-ai-btn" class="vne-ctrl-btn" title="{{localize 'vnd-enhanced.ui.aiGenerator'}}">
              <i class="fas fa-wand-sparkles"></i>
            </div>
            <div id="vne-presets-btn" class="vne-ctrl-btn" title="{{localize 'vnd-enhanced.ui.castPresets'}}">
              <i class="fas fa-layer-group"></i>
            </div>
            {{!-- GM-only: toggles the world-level background flag; players have no permission to save it --}}
            <div id="vne-hideback-btn" class="vne-ctrl-btn{{#if hideBack}} vne-active{{/if}}" title="{{localize 'vnd-enhanced.ui.toggleBackground'}}">
              <i class="fas fa-image"></i>
            </div>
          {{/if}}
          <div id="vne-chat-toggle-btn" class="vne-ctrl-btn vne-chat-toggle" title="{{localize 'vnd-enhanced.ui.toggleSidebar'}}">
            <i class="fas fa-bars"></i>
          </div>
          <div id="vne-hideUI-btn" class="vne-ctrl-btn vne-hideUI-toggle{{#if hideUI}} vne-active{{/if}}"
               title="{{#if hideUI}}{{localize 'vnd-enhanced.ui.showUI'}}{{else}}{{localize 'vnd-enhanced.ui.hideUI'}}{{/if}}">
            <i class="fas fa-{{#if hideUI}}eye{{else}}eye-slash{{/if}}"></i>
          </div>
          <div id="vne-help-btn" class="vne-ctrl-btn" title="{{localize 'vnd-enhanced.ui.helpBtn'}}">
            <i class="fas fa-question-circle"></i>
          </div>
          <div id="vne-close-btn" class="vne-ctrl-btn vne-close" title="{{localize 'vnd-enhanced.ui.close'}}">
            <i class="fas fa-times"></i>
          </div>
        </div>
        <div class="vne-location-info">
          {{#if locationParent}}
            <span id="vne-loc-parent" class="vne-loc-parent">{{locationParent}}</span>
            <span class="vne-loc-sep">›</span>
          {{/if}}
          <span id="vne-loc-name" class="vne-loc-name">{{#if locationName}}{{locationName}}{{else}}???{{/if}}</span>
          {{#if locationWeather}}
            <span class="vne-loc-weather"><i class="fas fa-cloud-sun"></i> {{locationWeather}}</span>
          {{/if}}
          {{#if locationTime}}
            <span class="vne-loc-time"><i class="fas fa-clock"></i> {{locationTime}}</span>
          {{/if}}
        </div>
      </div>

      {{!-- RIGHT: empty (sidebar is native Foundry, floats above VNE) --}}
      <div class="vne-top-right-section"></div>
    </div>

    {{!-- ── CAROUSEL ROW (below header, all combatants sorted by initiative) ── --}}
    <div id="vne-unified-carousel" class="vne-unified-carousel{{#unless combatMode}} vne-hidden{{/unless}}"></div>

    {{!-- ── COMBAT CONTROLS ROW (below carousel) ── --}}
    <div id="vne-combat-controls" class="vne-combat-controls{{#unless combatMode}} vne-hidden{{/unless}}">
      {{#if isGM}}
        <div id="vne-prev-turn-btn" class="vne-turn-nav-btn" title="{{localize 'vnd-enhanced.combat.prevTurn'}}">
          <i class="fas fa-step-backward"></i> {{localize 'vnd-enhanced.combat.prev'}}
        </div>
      {{/if}}

      <div class="vne-round-block">
        <div class="vne-round-label">{{localize 'vnd-enhanced.combat.round'}}</div>
        <div id="vne-round-num" class="vne-round-num">{{combatRound}}</div>
        <div id="vne-turn-name" class="vne-turn-name">{{combatTurnName}}</div>
      </div>

      {{#if isGM}}
        <div class="vne-timer-area">
          <input id="vne-timer-input" class="vne-timer-input" type="number"
            min="1" max="60" value="{{timerMinutes}}" title="{{localize 'vnd-enhanced.combat.timerMinutes'}}"/>
          <span class="vne-timer-unit">{{localize 'vnd-enhanced.ui.min'}}</span>
          <div id="vne-timer-toggle-btn" class="vne-ctrl-btn vne-timer-toggle{{#if timerEnabled}} vne-active{{/if}}"
               title="{{#if timerEnabled}}{{localize 'vnd-enhanced.combat.timerStop'}}{{else}}{{localize 'vnd-enhanced.combat.timerStart'}}{{/if}}">
            <i class="fas fa-hourglass-{{#if timerEnabled}}half{{else}}start{{/if}}"></i>
          </div>
          <div id="vne-timer-display" class="vne-timer-display{{#if timerEnabled}} vne-timer-running{{/if}}{{#if timerLow}} vne-timer-low{{/if}}">
            {{timerDisplay}}
          </div>
          <div id="vne-timer-auto-btn" class="vne-ctrl-btn vne-timer-auto{{#if timerAuto}} vne-active{{/if}}"
               title="{{#if timerAuto}}{{localize 'vnd-enhanced.combat.timerAutoOn'}}{{else}}{{localize 'vnd-enhanced.combat.timerAutoOff'}}{{/if}}">
            <i class="fas fa-sync-alt"></i>
          </div>
        </div>

        <div id="vne-roll-all-init-btn" class="vne-ctrl-btn" title="{{localize 'vnd-enhanced.combat.rollAllInit'}}">
          <i class="fas fa-dice-d20"></i>
        </div>

        <div id="vne-next-turn-btn" class="vne-turn-nav-btn" title="{{localize 'vnd-enhanced.combat.nextTurn'}}">
          {{localize 'vnd-enhanced.combat.next'}} <i class="fas fa-step-forward"></i>
        </div>
      {{/if}}
    </div>

    {{!-- ── STAGE AREA ── --}}
    <div class="vne-stage">

      {{!-- LEFT CAST DROP ZONE --}}
      <div class="vne-left-panel vne-side-panel vne-drop-zone" data-side="left">
        <div class="vne-side-label">
          {{#if isGM}}<div id="vne-add-left-btn" class="vne-add-cast-btn" title="{{localize 'vnd-enhanced.ui.addActorLeft'}}"><i class="fas fa-user-plus"></i></div>{{/if}}
          <span>{{localize 'vnd-enhanced.ui.players'}}</span>
        </div>
        {{!-- Populated by _patchSidePanel (single JS renderer — no template/JS drift) --}}
        <div id="vne-left-portraits" class="vne-portraits-list"></div>
      </div>

      {{!-- ROLEPLAY STAGE — column 2 in VN/RP mode (hidden in combat) --}}
      <div id="vne-rp-stage" class="vne-rp-stage vne-drop-zone"></div>

      {{!-- RIGHT CAST DROP ZONE --}}
      <div class="vne-right-panel vne-side-panel vne-drop-zone" data-side="right">
        <div class="vne-side-label">
          <span>{{localize 'vnd-enhanced.ui.npcs'}}</span>
          {{#if isGM}}<div id="vne-add-right-btn" class="vne-add-cast-btn" title="{{localize 'vnd-enhanced.ui.addActorRight'}}"><i class="fas fa-user-plus"></i></div>{{/if}}
        </div>
        {{!-- Populated by _patchSidePanel (single JS renderer — no template/JS drift) --}}
        <div id="vne-right-portraits" class="vne-portraits-list"></div>
      </div>

    </div>{{!-- /stage --}}

    {{!-- ── BOTTOM BAR: Scenes Pill ── --}}
    <div class="vne-bottom-bar">
      <div id="vne-scenes-pill" class="vne-scenes-pill" title="{{localize 'vnd-enhanced.scenes.pillTooltip' count=locationList.length}}">
        <i class="fas fa-map-marked-alt"></i>
        <span class="vne-sp-pill-label">{{localize 'vnd-enhanced.scenes.pillLabel'}}</span>
        <span class="vne-sp-pill-sep" style="{{#unless locationName}}display:none{{/unless}}">›</span>
        <span id="vne-scenes-current" class="vne-sp-pill-current" style="{{#unless locationName}}display:none{{/unless}}">{{locationName}}</span>
        <span class="vne-sp-pill-count">({{locationList.length}})</span>
      </div>
    </div>

    {{!-- ── PLAYER LIST (top-right collapsible) ── --}}
    {{#if isGM}}
      <div class="vne-player-panel">
        <div class="vne-player-panel-title">{{localize 'vnd-enhanced.ui.playerPanelTitle'}}</div>
        {{#each players as |pl|}}
          <div class="vne-player-row{{#unless pl.visible}} vne-player-hidden{{/unless}}"
               data-user-id="{{pl.id}}"
               title="{{pl.name}}">
            <span class="vne-player-dot" style="background:{{pl.color}};"></span>
            <span class="vne-player-name">{{pl.name}}</span>
            <button type="button" class="vne-player-vis-btn" data-user-id="{{pl.id}}"
              title="{{#if pl.visible}}{{localize 'vnd-enhanced.ui.hideFrom' name=pl.name}}{{else}}{{localize 'vnd-enhanced.ui.showTo' name=pl.name}}{{/if}}">
              <i class="fas fa-{{#if pl.visible}}eye{{else}}eye-slash{{/if}}"></i>
            </button>
          </div>
        {{/each}}
        <button type="button" id="vne-show-all-btn" class="vne-show-all-btn">
          <i class="fas fa-users"></i> {{localize 'vnd-enhanced.ui.showAll'}}
        </button>
      </div>
    {{/if}}

  </div>{{!-- /ui-layer --}}

</div>
